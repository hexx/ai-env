{
  "name": "ai-env",
  "version": "0.1.0",
  "description": "私専用のAI開発用Dockerサンドボックス環境を簡単に起動するCLI",
  "private": true,
  "bin": {
    "ai-env": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx index.ts",
    "build": "esbuild index.ts --bundle --platform=node --format=cjs --banner:js=\"#!/usr/bin/env node\" --outfile=dist/index.js",
    "prepack": "npm run build",
    "test": "node --import tsx --test *.test.ts",
    "test:watch": "node --import tsx --test --watch *.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "strip-json-comments": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.0"
  }
}
