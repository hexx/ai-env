{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-console": "off",
    "capitalized-comments": "off",
    "import-style": "off"
  },
  "env": {
    "builtin": true
  }
}
